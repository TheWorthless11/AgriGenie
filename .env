# AgriGenie Development Configuration
# Copy this file to .env and fill in your Gmail App Password

# Django Settings
DEBUG=True
SECRET_KEY=django-insecure-c_d(!7w@5y3p#d=x29gs=nlf4sinvydu4axb(*!@9g2im#$(nw
ALLOWED_HOSTS=localhost,127.0.0.1

# Email Configuration - Gmail SMTP
# To get your App Password:
# 1. Go to https://myaccount.google.com/security
# 2. Enable "2-Step Verification" (if not already enabled)
# 3. Go to "App passwords" section
# 4. Select "Mail" and "Windows"
# 5. Generate new password
# 6. Copy the 16-character password (with or without spaces)

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=xxxx-xxxx-xxxx-xxxx
DEFAULT_FROM_EMAIL=your-email@gmail.com

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Cache Configuration
CACHE_URL=redis://127.0.0.1:6379/1

# Weather API
WEATHER_API_KEY=demo_key
