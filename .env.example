# ==========================================
# Template for Local Environment Variables
# Copy this file, rename it to .env, and 
# fill in your own local credentials.
# ==========================================

# Django Core Settings
DEBUG=True
SECRET_KEY=your_secret_key_here
ALLOWED_HOSTS=localhost,127.0.0.1,.trycloudflare.com
CSRF_TRUSTED_ORIGINS=https://*.trycloudflare.com
TRUST_X_FORWARDED_PROTO=True
USE_X_FORWARDED_HOST=True

# Database Configuration (PostgreSQL)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=agrigenie_db
DB_USER=postgres
DB_PASSWORD=postgres
# Use DB_HOST=db when running with docker-compose
DB_HOST=127.0.0.1
DB_PORT=5432

# Email Configuration (Ask team lead for test credentials)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_gmail_app_password_here

# Google OAuth Credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Cloudflare Tunnel Configuration
# quick = random trycloudflare URL (changes on restart)
# named = stable custom hostname (recommended for Google OAuth)
CLOUDFLARE_TUNNEL_MODE=quick
CLOUDFLARE_TUNNEL_NAME=agrigenie
CLOUDFLARE_TUNNEL_ID=
CLOUDFLARE_TUNNEL_CREDENTIALS_FILE=
CLOUDFLARE_TUNNEL_HOSTNAME=
CLOUDFLARE_TUNNEL_ORIGIN_CERT=

# Redis / Celery / Channels Configuration
# Use REDIS_HOST=redis and redis://redis:6379/... when running with docker-compose
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0
CACHE_URL=redis://127.0.0.1:6379/1

# 3rd Party APIs
WEATHER_API_KEY=your_weather_api_key_here